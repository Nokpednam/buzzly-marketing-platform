# ─── Supabase DB Connection for seed script ───────────────────────────────────
# Get these values from: Supabase Dashboard → Settings → Database

# Option A (easiest): full connection string (Transaction Pooler)
# DATABASE_URL=postgresql://postgres.xpmswnktazcjpqumrfsh:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Option B: just the DB password (VITE_SUPABASE_URL is already set in vite)
# SUPABASE_DB_PASSWORD=your_database_password_here

# ─── Already in project (from Supabase dashboard → API keys) ────────────────
# VITE_SUPABASE_URL=https://xpmswnktazcjpqumrfsh.supabase.co
# VITE_SUPABASE_ANON_KEY=...
