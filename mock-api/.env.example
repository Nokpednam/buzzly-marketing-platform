# Mock API Server — Environment Variables
# Copy this file to mock-api/.env and fill in the values.
# Run: supabase status  (to get SUPABASE_SERVICE_ROLE_KEY for local dev)

# ── External API source ───────────────────────────────────────────────
# Where this backend fetches platform data from.
# In dev it points back to our own mock fixture endpoints (localhost:3001).
# In production, replace with the real platform base URL.
EXTERNAL_API_BASE_URL=http://localhost:3001

# ── Supabase (for server-side DB writes, bypasses RLS) ───────────────
SUPABASE_URL=http://127.0.0.1:54321

# Get this from: supabase status  →  "service_role key"
# Local dev default (safe to use locally, never commit the real prod key):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SJBo

# ── Server port (optional, defaults to 3001) ──────────────────────────
# PORT=3001
