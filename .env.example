# Environment Variables Template
# Copy this file to .env and update with your values

# Supabase Configuration
# These are set automatically when you run: npx supabase start
VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH"

# Error Logging Configuration
# Set to 'false' to disable error logging (defaults to enabled)
VITE_ENABLE_ERROR_LOGGING="true"

# Backend / Mock API server URL
# The frontend sends API keys here for validation and data ingestion.
# In dev this is the mock-api Express server (port 3001).
VITE_BACKEND_API_URL="http://localhost:3001"

# NOTE: For local development, these values are automatically generated by Supabase CLI
# You don't need to change them unless you're connecting to a remote Supabase instance
